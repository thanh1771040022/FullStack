# Backend (backend/.env)
PORT=3000
NODE_ENV=production
JWT_SECRET=change_me_to_a_long_random_secret

DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=quan_ly_doi_xe

# Deadline Alert Scheduler
# true/false - tu dong tao canh bao han muc dinh ky
ENABLE_DEADLINE_ALERT_JOB=true
# Chu ky chay job (phut)
ALERT_CHECK_INTERVAL_MINUTES=30
# SLA nhac han (ngay), cach nhau boi dau phay
ALERT_SLA_DAYS=30,14,7,3,1
