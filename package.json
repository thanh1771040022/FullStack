{
  "name": "vue-01",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "eslint . --fix --cache --config eslint.config.js",
    "lint:backend": "eslint backend --fix --cache --config backend/eslint.config.js",
    "lint:frontend:ci": "eslint . --config eslint.config.js",
    "lint:backend:ci": "eslint backend --config backend/eslint.config.js",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.5.1",
    "globals": "^16.5.0",
    "prettier": "3.6.2",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5"
  }
}
